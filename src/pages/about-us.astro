---
/**
 * /about-us —— About 内容页（page 文档驱动，slug "about-us"，见 ADR-0001 保留 legacy URL）。
 *
 * 数据：build 时按 slug 拉 `page` 文档；有 body 则用 RichTextRenderer 渲染编辑正文，
 * 否则降级为**静态 editorial 回落**（文案核对自线上 Wix About 页，澳洲拼写，
 * 修正其拼写 “Quailty”→正常正文；绝不 lorem）。
 *
 * SEO：唯一 title / meta description（优先用编辑填的 seo，否则回落）；canonical 自指
 * （BaseLayout 取当前路径）。Breadcrumbs：Home > About Us（含 BreadcrumbList JSON-LD）。
 * 纯静态（SSG），零 client JS。
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import HeroImageSection from "@/components/HeroImageSection.astro";
import EditorialTextBlock from "@/components/EditorialTextBlock.astro";
import ImageTextSplit from "@/components/ImageTextSplit.astro";
import RichTextRenderer from "@/components/RichTextRenderer.astro";
import SampleRequestButton from "@/components/SampleRequestButton.astro";
import ProductCarousel from "@/components/ProductCarousel.tsx";
import {
  getPageBySlug,
  hasBody,
  buildContentBreadcrumbs,
  buildContentSeo,
} from "@/lib/content-pages";
import { getFeaturedProducts } from "@/lib/category-page";

const PATH = "/about-us";
const SLUG = "about-us";
const FALLBACK_TITLE = "About Us";
const FALLBACK_DESCRIPTION =
  "Maywood Flooring is a premium timber flooring wholesaler in Keysborough, Melbourne — pairing decades of Australian timber expertise with precision craftsmanship for trade and homeowners across Victoria.";

const page = await getPageBySlug(SLUG);

const title = page?.title ?? FALLBACK_TITLE;
const breadcrumbs = buildContentBreadcrumbs(PATH, title);
const seo = buildContentSeo({
  path: PATH,
  page,
  fallbackTitle: FALLBACK_TITLE,
  fallbackDescription: FALLBACK_DESCRIPTION,
});

const showBody = hasBody(page);

// 「Explore Our Products」轮播：跨分类精选产品（仅有图的已发布产品）。
// Phase 1 product 未灌入 → 空数组 → 区块整体不渲染（优雅降级）。
const featuredProducts = await getFeaturedProducts(8);
---

<BaseLayout {...seo}>
  <article class="about">
    <div class="about__crumbs">
      <Breadcrumbs items={breadcrumbs} />
    </div>

    <HeroImageSection
      title={title}
      eyebrow="About Maywood"
      intro="See how Maywood pairs quality materials and precision craftsmanship to bring Australian homes and businesses the flooring experience they deserve."
      image={page?.heroImage ?? null}
      sampleCta
    />

    {
      showBody ? (
        <EditorialTextBlock>
          <RichTextRenderer value={page!.body} />
        </EditorialTextBlock>
      ) : (
        <>
          {/* 静态 editorial 回落（核对自线上 Wix About 页，澳洲拼写）。 */}
          <EditorialTextBlock
            heading="Your Trusted Flooring Partner"
            paragraphs={[
              "With decades of deep-rooted expertise in the Australian timber industry, Maywood Flooring harmonises traditional craftsmanship with cutting-edge technology to deliver unmatched quality and structural integrity.",
              "From rigorous density selection to moisture-controlled precision, our collections are curated to evoke the naturalistic style of Australian homes while balancing timeless beauty with local resilience. Every plank we craft upholds strict sustainability standards, so the elegance we bring into your space is built responsibly and designed to last a lifetime.",
            ]}
          />

          <ImageTextSplit
            eyebrow="Pure Oak. Pure Design."
            heading="A wholesaler dedicated to the trade"
            paragraphs={[
              "Maywood is a premier timber flooring wholesaler dedicated to supplying the finest European Oak, American Oak and Ash to the professional trade. We specialise in large-format engineered planks and bespoke parquetry that balance aesthetic elegance with structural integrity.",
              "By combining direct-to-trade distribution with uncompromising quality control, Maywood delivers the foundation for Australia's most inspired architectural spaces.",
            ]}
          />

          {/* Step on Quality —— 文字 + Request-a-Sample CTA（对齐 Wix About 区块）。 */}
          <EditorialTextBlock
            eyebrow="Step on Quality"
            heading="Feel the Maywood difference"
          >
            <div class="about__cta-block">
              <p>
                The truest measure of a floor is underfoot. Request a sample to
                experience our timber's grain, finish and weight in your own
                space before you commit — no showroom visit required.
              </p>
              <SampleRequestButton />
            </div>
          </EditorialTextBlock>
        </>
      )
    }

    {
      featuredProducts.length > 0 && (
        <section class="about__products" aria-labelledby="about-products-title">
          <h2 id="about-products-title" class="about__products-title">
            Explore Our Products
          </h2>
          <ProductCarousel items={featuredProducts} client:visible />
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  .about__crumbs {
    max-width: 80rem;
    margin-inline: auto;
    padding: 1.25rem clamp(1rem, 4vw, 2.5rem) 0;
  }

  /* Step on Quality 区块：居中文字 + CTA 按钮（呼应 editorial 留白）。 */
  .about__cta-block {
    max-width: 44rem;
    margin-inline: auto;
    text-align: center;
  }
  .about__cta-block p {
    margin: 0 0 1.75rem;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-ink);
  }

  /* Explore Our Products 轮播区。 */
  .about__products {
    max-width: 80rem;
    margin-inline: auto;
    padding: var(--spacing-section) clamp(1rem, 4vw, 2.5rem);
  }
  .about__products-title {
    margin: 0 0 clamp(2rem, 4vw, 3rem);
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1.1;
    color: var(--color-ink);
    text-align: center;
  }
</style>
