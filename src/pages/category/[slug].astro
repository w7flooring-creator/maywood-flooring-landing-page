---
/**
 * /category/[slug] —— store 视图：Category(3) + Collection(9) = 12 页。
 *
 * getStaticPaths 从 getCategoryStoreViews() 取「3 个材质 Category + 9 个品牌 Collection」
 * 统一成 CategoryStoreView，一条路由产出 12 条。Wix 把 Collection 也暴露在
 * /category/<collection-slug>（如 /category/puregrain），ADR-0001 把 /category/ 列为
 * 1:1 保留前缀 → 必须渲染、不 301。漏掉 Collection 时这些 URL 404、且分类页侧栏
 * "Browse by" 链接全断。
 *
 * 两个 Category slug 与展示名不符（solid-flooring=Laminate、sustainable-flooring=Hybrid）
 * ——故意保留 Wix 历史值（ADR-0001），展示名取 Sanity title，不在代码里硬编码。
 *
 * 本地匿名读 dataset 返回空 → getStaticPaths 产 0 页，build 0 页，属预期
 * （CI/prod 有 SANITY_API_READ_TOKEN → 拉到 12 个 store 视图生成 12 页，见 ADR-0003）。
 * 正确性由单测（纯逻辑：路径/面包屑/canonical）+ mock 渲染保证，而非本地页数。
 *
 * intro 文案来自 Sanity description（编辑可改成与实际材质/系列相符），不硬编码措辞。
 * canonical：Category 与非招牌 Collection 指自身 /category/<slug>；招牌 Collection 指
 * 其营销落地页 /<slug>（两者近重复，见 buildStoreSeo / ADR-0001）。纯静态。
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import CategoryHero from "@/components/CategoryHero.astro";
import CategoryIntro from "@/components/CategoryIntro.astro";
import CategorySidebar from "@/components/CategorySidebar.astro";
import ProductCount from "@/components/ProductCount.astro";
import ProductGrid from "@/components/ProductGrid.astro";
import {
  getCategoryStoreViews,
  toStorePaths,
  getStoreProducts,
  getStoreSidebarCategorySlug,
  buildStoreBreadcrumbs,
  buildStoreSeo,
  type CategoryStoreView,
} from "@/lib/category-page";
import { getCollectionsByCategory } from "@/lib/taxonomy";

export async function getStaticPaths() {
  const views = await getCategoryStoreViews();
  return toStorePaths(views);
}

interface Props {
  view: CategoryStoreView;
}

const { view } = Astro.props as Props;

// 侧栏 "Browse by"：Category 列其下 Collection；Collection 列同父 Category 的兄弟系列。
// 产品网格按 kind 取数（Category 含 extraCategories 并集；Collection 按单一 collection 引用）。
const collections = await getCollectionsByCategory(
  getStoreSidebarCategorySlug(view)
);
const products = await getStoreProducts(view);

const breadcrumbs = buildStoreBreadcrumbs(view);
const seo = buildStoreSeo(view);

// #59-#20：标题旁小装饰图标（仅 Laminate 对齐 Wix；slug=solid-flooring 见 ADR-0001）。
const CATEGORY_TITLE_ICONS: Record<string, "layers"> = {
  "solid-flooring": "layers",
};
const titleIcon = CATEGORY_TITLE_ICONS[view.slug] ?? null;
---

<BaseLayout {...seo} motionProfile="catalog">
  <div class="category">
    <div class="category__crumbs">
      {
        /* Breadcrumbs 同时渲染语义 nav 与 BreadcrumbList JSON-LD（见组件注释）。 */
      }
      <Breadcrumbs items={breadcrumbs} />
    </div>

    {
      /* 仅在有 heroImage 时渲染宽幅 hero（对齐 Wix：无图分类页是纯文字块，
         不放 muted 占位带；标题统一由下方 CategoryIntro 的 H1 承担，避免重复标题。
         #59 对齐项）。配图入库后此 hero 自动出现。 */
      view.heroImage?.url && (
        <CategoryHero
          title={view.title}
          eyebrow="Products"
          image={view.heroImage}
        />
      )
    }

    <div class="category__body">
      <aside class="category__sidebar">
        <CategorySidebar collections={collections} />
      </aside>

      <section class="category__main" aria-label={view.title}>
        {
          /* Collection store 视图只渲染 H1 不渲染 description——系列营销叙事
             属于 /<slug> 落地页（CollectionNarrative），店铺网格页保持干净；
             description 仍参与 SEO meta 回落（buildStoreSeo）。
             Category 视图照常渲染 intro（含 ADR-0001 内容债修正文案）。 */
        }
        <CategoryIntro
          title={view.title}
          description={view.kind === "collection" ? null : view.description}
          icon={titleIcon}
        />
        <div class="category__count">
          <ProductCount count={products.length} />
        </div>
        <ProductGrid products={products} />
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .category__crumbs {
    max-width: 72rem;
    margin-inline: auto;
    padding: 1.25rem 1.25rem 0;
  }

  .category__body {
    max-width: 72rem;
    margin-inline: auto;
    padding: clamp(2rem, 5vw, 3.5rem) 1.25rem var(--spacing-section);
    display: grid;
    gap: clamp(2rem, 4vw, 3rem);
  }

  /* 桌面：左 Browse-by 侧栏 + 右主内容（呼应 AGENTS.md「左侧 Browse by sidebar」）。 */
  @media (min-width: 60rem) {
    .category__body {
      grid-template-columns: 16rem 1fr;
      align-items: start;
    }
  }

  .category__count {
    margin: 1.5rem 0;
  }
</style>
