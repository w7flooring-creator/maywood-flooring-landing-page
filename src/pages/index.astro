---
/**
 * 首页（/）—— 上半（#15）：HomeHero + ProductSelectionGrid；
 * 下半（#16）：PartnerNarrative / SilentFoundation / SignatureCollections /
 * BrandStatement / GalleryFeed / HomeCta，顺序对照线上 Wix 首页。
 *
 * SEO 元信息走 BaseLayout → SeoHead（唯一 title/desc、canonical、OG、
 * LocalBusiness JSON-LD）。全页**唯一 h1** 在 HomeHero，下半全部用 h2/h3。
 * 纯静态（SSG，零 client JS）。
 *
 * 配图均由 Sanity 驱动（build 时拉），生产走 Sanity CDN 不热链 Wix；本地 / 匿名读
 * 无 token 时为空 → 各组件优雅降级（见 ADR-0003）。配图来源：
 *  - hero / partner / accessories → homePage 单例（scripts/import-home-images.ts）；
 *  - 产品入口卡 → 各 Category heroImage；招牌系列卡 → 各 Collection heroImage；
 *  - GalleryFeed → galleryImage（scripts/import-gallery.ts，取前 8 张）。
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import HomeHero from "@/components/HomeHero.astro";
import ProductSelectionGrid from "@/components/ProductSelectionGrid.astro";
import PartnerNarrativeSection from "@/components/PartnerNarrativeSection.astro";
import SilentFoundationSection from "@/components/SilentFoundationSection.astro";
import SignatureCollectionsSection from "@/components/SignatureCollectionsSection.astro";
import HomeSustainabilitySection from "@/components/HomeSustainabilitySection.astro";
import BrandStatementSection from "@/components/BrandStatementSection.astro";
import GalleryFeedSection from "@/components/GalleryFeedSection.astro";
import HomeCtaSection from "@/components/HomeCtaSection.astro";
import { getSignatureCollections } from "@/lib/taxonomy";
import { getGalleryItems } from "@/lib/gallery";
import { getHomePageImages } from "@/lib/home-content";
import { getCategoryLandings } from "@/lib/category-page";

// 招牌系列 build 时拉取（无 token / 匿名读 → 空数组，区块优雅降级）。
const signatureCollections = await getSignatureCollections();

// 首页专属配图（hero / partner / accessories）build 时从 Sanity homePage 单例拉取。
const homeImages = await getHomePageImages();

// 产品入口卡复用各 Category 的 heroImage（按 href 索引）；Accessories→Contact 用 homePage.accessoriesImage。
const categories = await getCategoryLandings();
const categoryImageBySlug = new Map(
  categories.map((c) => [c.slug, c.heroImage])
);
const productImagesByHref: Record<
  string,
  { url: string; alt: string | null } | null
> = {
  "/category/engineered-flooring":
    categoryImageBySlug.get("engineered-flooring") ?? null,
  "/category/solid-flooring": categoryImageBySlug.get("solid-flooring") ?? null,
  "/category/sustainable-flooring":
    categoryImageBySlug.get("sustainable-flooring") ?? null,
  "/contact": homeImages.accessoriesImage,
};

// 图库图片 build 时拉取，首页 GalleryFeed 取前 8 张（无内容 → 组件回落占位 strip）。
const galleryFeedImages = (await getGalleryItems()).slice(0, 8).map((g) => ({
  url: g.url,
  alt: g.alt ?? "Maywood Flooring flooring project, Melbourne",
}));
---

<BaseLayout
  title="Premium Timber, Laminate & Hybrid Flooring in Melbourne"
  description="Maywood Flooring is a premium timber, laminate and hybrid flooring supplier in Keysborough, Melbourne — serving trade, wholesale and homeowners across Victoria."
>
  <HomeHero
    imageUrl={homeImages.heroImage?.url ?? null}
    imageAlt={homeImages.heroImage?.alt ?? undefined}
  />
  <ProductSelectionGrid imagesByHref={productImagesByHref} />
  <PartnerNarrativeSection image={homeImages.partnerImage} />
  <SilentFoundationSection image={homeImages.silentFoundationImage} />
  <SignatureCollectionsSection collections={signatureCollections} />
  <HomeSustainabilitySection image={homeImages.sustainabilityImage} />
  <BrandStatementSection />
  <GalleryFeedSection images={galleryFeedImages} />
  <HomeCtaSection />
</BaseLayout>
