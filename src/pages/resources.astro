---
/**
 * /resources —— Resources 列表页（resource 文档驱动；保留 legacy URL 见 ADR-0001）。
 *
 * 数据：build 时拉全部 `resource`（按 publishedAt 新→旧）。有条目则渲染卡片网格，
 * 否则降级为优雅空状态（一句符合事实的说明 + Contact CTA，绝不 lorem / 占位卡）。
 *
 * 卡片为信息卡（标题 + 分类 + 摘要 + 缩略图），并带 per-card「View more」文字链接
 * 指向资料详情页 /resources/<slug>（#67：详情路由 src/pages/resources/[slug].astro 已上线）。
 * 每条 resource 都有 slug（schema 必填），故每卡都渲染链接。
 * SEO：唯一 title / meta description；canonical 自指。纯静态（SSG），零 client JS。
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import HeroImageSection from "@/components/HeroImageSection.astro";
import { sanityImageUrl, sanityImageSrcset } from "@/lib/sanity-image";
import {
  getResources,
  buildContentBreadcrumbs,
  buildContentSeo,
} from "@/lib/content-pages";

const PATH = "/resources";
const TITLE = "Resources";
const DESCRIPTION =
  "Technical resources for your project — Maywood Flooring brochures, technical data sheets, installation and care guides, warranty terms and compliance reports for timber, laminate and hybrid flooring.";

const resources = await getResources();
const hasResources = resources.length > 0;

const breadcrumbs = buildContentBreadcrumbs(PATH, TITLE);
const seo = buildContentSeo({
  path: PATH,
  page: null,
  fallbackTitle: TITLE,
  fallbackDescription: DESCRIPTION,
});
---

<BaseLayout {...seo} motionProfile="editorial">
  <section class="resources">
    <div class="resources__crumbs">
      <Breadcrumbs items={breadcrumbs} />
    </div>

    <HeroImageSection
      title={TITLE}
      eyebrow="Resources"
      intro="Comprehensive technical resources to support your project from specification to installation — product data, compliance reports and maintenance guides."
    />

    <div class="resources__body">
      {
        hasResources ? (
          <ul class="resources__grid" role="list" data-motion-scene="grid">
            {resources.map((r) => (
              <li class="resource-card" data-motion-layer="card">
                {r.heroImage && (
                  <div class="resource-card__media" data-motion-layer="media">
                    <img
                      src={sanityImageUrl(r.heroImage.url, { width: 640 })}
                      srcset={
                        sanityImageSrcset(
                          r.heroImage.url,
                          [320, 480, 640, 800]
                        ) || undefined
                      }
                      sizes="(min-width: 60rem) 360px, 45vw"
                      alt={r.heroImage.alt ?? ""}
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                )}
                <div class="resource-card__text">
                  {r.category && (
                    <p class="resource-card__category">{r.category}</p>
                  )}
                  <h2 class="resource-card__title">{r.title}</h2>
                  {r.excerpt && (
                    <p class="resource-card__excerpt">{r.excerpt}</p>
                  )}
                  {/* per-card「View more」→ 资料详情页。aria-label 含资料标题，
                      让重复的「View more」对读屏用户可区分。 */}
                  <a
                    class="resource-card__more"
                    href={`/resources/${r.slug}`}
                    aria-label={`View more: ${r.title}`}
                  >
                    <span>View more</span>
                    <span class="resource-card__more-arrow" aria-hidden="true">
                      &rarr;
                    </span>
                  </a>
                </div>
              </li>
            ))}
          </ul>
        ) : (
          <div
            class="resources__empty"
            data-motion-scene="cta"
            data-motion-layer="copy"
          >
            <p>
              Our resource library is being prepared. For brochures, technical
              data sheets, installation and care guides, or compliance reports,
              please get in touch and our team will send the documents you need.
            </p>
            <a class="resources__cta" href="/contact">
              Contact our team
            </a>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .resources__crumbs {
    max-width: 80rem;
    margin-inline: auto;
    padding: 1.25rem clamp(1rem, 4vw, 2.5rem) 0;
  }

  .resources__body {
    max-width: 80rem;
    margin-inline: auto;
    padding: var(--spacing-section) clamp(1rem, 4vw, 2.5rem);
  }

  .resources__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: clamp(1.5rem, 4vw, 2.5rem);
    grid-template-columns: 1fr;
  }

  @media (min-width: 40rem) {
    .resources__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 64rem) {
    .resources__grid {
      /* 固定 8 张资源卡 → 桌面四列（2×4），无孤行，贴合 Wix 密集网格观感。 */
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .resource-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border: 1px solid var(--color-border-hairline);
    border-radius: var(--radius-cta);
    overflow: hidden;
  }

  .resource-card__media {
    aspect-ratio: 4 / 3;
    background: var(--color-bg-muted);
  }
  .resource-card__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .resource-card__text {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: clamp(1.25rem, 3vw, 1.75rem);
  }

  .resource-card__category {
    margin: 0 0 0.5rem;
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #777;
  }

  .resource-card__title {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 1.35rem;
    line-height: 1.2;
    color: var(--color-ink);
  }

  .resource-card__excerpt {
    margin: 0.75rem 0 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--muted-foreground);
  }

  /* 克制的 editorial 文字链接 + 箭头（非按钮）。auto 顶到卡片底部对齐。 */
  .resource-card__more {
    margin-top: auto;
    padding-top: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    align-self: flex-start;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink);
    text-decoration: none;
  }
  .resource-card__more span:first-child {
    text-decoration: underline;
    text-underline-offset: 0.22em;
    text-decoration-thickness: 1px;
  }
  .resource-card__more-arrow {
    transition: transform 0.2s ease;
  }
  .resource-card__more:hover .resource-card__more-arrow,
  .resource-card__more:focus-visible .resource-card__more-arrow {
    transform: translateX(0.2rem);
  }
  .resource-card__more:hover span:first-child {
    text-decoration-thickness: 2px;
  }

  /* 优雅空状态：克制居中说明 + 深色圆角小 CTA（呼应品牌 CTA token）。 */
  .resources__empty {
    max-width: 38rem;
    margin-inline: auto;
    text-align: center;
  }
  .resources__empty p {
    margin: 0 0 1.75rem;
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-ink);
  }
  .resources__cta {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--color-cta);
    color: #fff;
    border-radius: var(--radius-cta);
    text-decoration: none;
    font-size: 0.95rem;
  }
  .resources__cta:hover {
    opacity: 0.9;
  }
</style>
