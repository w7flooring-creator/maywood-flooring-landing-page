---
/**
 * CategoryHero —— 分类页顶部宽幅 muted hero。
 *
 * 设计为「内容未灌入也好看」（呼应 CollectionHero，但默认 muted 底色）：
 *  - 有 heroImage：宽幅暖色主图 + 白色内容面板叠放分类名 + 可选 eyebrow。
 *  - 无 heroImage：muted 背景 + 居中 serif 大标题，留白主导，绝不放占位图/lorem。
 *
 * H1 由 CategoryIntro 承担（页面唯一 H1），故本 hero 标题用 <p>，避免双 H1。
 * 纯静态（零 client JS）。视觉用品牌 token（serif 大标题、muted 背景、editorial 留白）。
 */
import type { CategoryHeroImage } from "@/lib/category-page";
import { sanityImageUrl, sanityImageSrcset } from "@/lib/sanity-image";

interface Props {
  title: string;
  /** 可选 eyebrow（如 "Products"）；缺省不渲染。 */
  eyebrow?: string | null;
  image?: CategoryHeroImage | null;
}

const { title, eyebrow = null, image = null } = Astro.props;
const hasImage = image !== null;
// hero 图在首屏 → 不 lazy load（首屏 LCP 元素）；alt 缺省给空串（装饰性回落）。
const altText = image?.alt ?? "";
---

<section class:list={["hero", { "hero--image": hasImage }]}>
  {
    hasImage && (
      <img
        class="hero__bg"
        src={sanityImageUrl(image!.url, { width: 1440 })}
        srcset={
          sanityImageSrcset(image!.url, [768, 1080, 1440, 1920]) || undefined
        }
        sizes="100vw"
        alt={altText}
        fetchpriority="high"
        loading="eager"
        decoding="async"
      />
    )
  }
  <div class="hero__panel">
    {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
    <p class="hero__title">{title}</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: clamp(16rem, 32vw, 26rem);
    padding: var(--spacing-section) 1.25rem;
    background: var(--color-bg-muted);
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  /* 有图时给内容面板一块白底，保证 serif 标题对比度（呼应首页 hero 白面板）。 */
  .hero--image .hero__panel {
    position: relative;
    z-index: 1;
    background: var(--color-bg);
    padding: clamp(2rem, 5vw, 3.5rem);
    max-width: 44rem;
    text-align: center;
  }

  .hero__panel {
    text-align: center;
  }

  .hero__eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #777;
  }

  .hero__title {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2.25rem, 5.5vw, 4rem);
    line-height: 1.05;
    color: var(--color-ink);
  }
</style>
