---
/**
 * CategoryHero —— 分类页顶部宽幅装饰性图片 banner。
 *
 * 分类名（页面唯一 H1）由下方 CategoryIntro 承担；本 hero **不再重复渲染标题**，
 * 避免与 intro 的 H1 形成重复标题（#59 对齐项：Wix 分类名只出现一次）。
 * 标题经 aria-label 提供给读屏（section 有可读名），可选 eyebrow（如 "Products"）。
 * 调用页仅在有 heroImage 时渲染本组件（无图分类页是纯文字块，对齐 Wix）。
 *
 * 纯静态（零 client JS）。视觉用品牌 token（暖色主图、editorial 留白）。
 */
import type { CategoryHeroImage } from "@/lib/category-page";
import { sanityImageUrl, sanityImageSrcset } from "@/lib/sanity-image";

interface Props {
  title: string;
  /** 可选 eyebrow（如 "Products"）；缺省不渲染。 */
  eyebrow?: string | null;
  image?: CategoryHeroImage | null;
}

const { title, eyebrow = null, image = null } = Astro.props;
// 仅当真正有可渲染 url 才算有图（heroImage 字段可能存在但 asset 为空 → url null）。
const hasImage = image?.url != null && image.url.length > 0;
// hero 图在首屏 → 不 lazy load（首屏 LCP 元素）；alt 缺省给空串（装饰性回落）。
const altText = image?.alt ?? "";
---

<section class:list={["hero", { "hero--image": hasImage }]} aria-label={title}>
  {
    hasImage && (
      <img
        class="hero__bg"
        src={sanityImageUrl(image!.url, { width: 1440 })}
        srcset={
          sanityImageSrcset(image!.url, [768, 1080, 1440, 1920]) || undefined
        }
        sizes="100vw"
        alt={altText}
        fetchpriority="high"
        loading="eager"
        decoding="async"
      />
    )
  }
  {
    eyebrow && (
      <div class="hero__panel">
        <p class="hero__eyebrow">{eyebrow}</p>
      </div>
    )
  }
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: clamp(16rem, 32vw, 26rem);
    padding: var(--spacing-section) 1.25rem;
    background: var(--color-bg-muted);
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  /* 有图时给内容面板一块白底，保证 serif 标题对比度（呼应首页 hero 白面板）。 */
  .hero--image .hero__panel {
    position: relative;
    z-index: 1;
    background: var(--color-bg);
    padding: clamp(2rem, 5vw, 3.5rem);
    max-width: 44rem;
    text-align: center;
  }

  .hero__panel {
    text-align: center;
  }

  .hero__eyebrow {
    margin: 0;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #777;
  }
</style>
