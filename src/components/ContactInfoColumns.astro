---
/**
 * ContactInfoColumns —— Contact 页 "Contact Us" 区，三栏 Address / Contact / Opening Hours。
 *
 * Address 与 Contact 渠道全部取自 site.ts 的 NAP 单一来源（禁止硬编码，保 NAP 全站一致）；
 * Opening Hours 委托给 OpeningHours 组件（静态营业时间）。Contact 栏含 phone(tel:)、
 * email(mailto:) 与 WhatsAppCta。地址用 <address> 语义包裹，每栏一个 <h3> 标题。
 * 纯静态、零 client JS。
 */
import { NAP } from "@/lib/site";
import OpeningHours from "@/components/OpeningHours.astro";
import WhatsAppCta from "@/components/WhatsAppCta.astro";

const { street, locality, region, postalCode } = NAP.address;
// 拨号用规整为 tel: 格式（去空格），与 SiteFooter 同约定。
const telHref = `tel:${NAP.phone.replace(/\s+/g, "")}`;
---

<section class="contact-info" aria-labelledby="contact-info-heading">
  <div class="contact-info__inner">
    <h2 id="contact-info-heading" class="contact-info__title">Contact Us</h2>

    <div class="contact-info__cols">
      <div class="contact-info__col">
        <h3 class="contact-info__heading">Address</h3>
        <address class="contact-info__address">
          {street}<br />
          {locality}, {region}
          {postalCode}<br />
          Australia
        </address>
      </div>

      <div class="contact-info__col">
        <h3 class="contact-info__heading">Contact</h3>
        <ul class="contact-info__list">
          <li>
            <a class="contact-info__link" href={telHref}>{NAP.phone}</a>
          </li>
          <li>
            <a class="contact-info__link" href={`mailto:${NAP.email}`}>
              {NAP.email}
            </a>
          </li>
        </ul>
        <WhatsAppCta class="contact-info__whatsapp" />
      </div>

      <div class="contact-info__col">
        <h3 class="contact-info__heading">Opening Hours</h3>
        <OpeningHours />
      </div>
    </div>
  </div>
</section>

<style>
  .contact-info {
    background: var(--color-bg);
    padding: var(--spacing-section) 0;
  }
  .contact-info__inner {
    max-width: 80rem;
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 2.5rem);
  }
  .contact-info__title {
    margin: 0 0 clamp(2rem, 4vw, 3rem);
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.9rem, 4vw, 2.75rem);
    line-height: 1.1;
    color: var(--color-ink);
  }

  .contact-info__cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3.5rem);
  }
  @media (min-width: 48rem) {
    .contact-info__cols {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .contact-info__heading {
    margin: 0 0 1rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  .contact-info__address {
    font-style: normal;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-ink);
  }

  .contact-info__list {
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .contact-info__link {
    color: var(--color-ink);
    text-decoration: none;
    font-size: 0.95rem;
    transition: opacity 150ms ease;
  }
  .contact-info__link:hover {
    opacity: 0.7;
    text-decoration: underline;
  }
</style>
