---
/**
 * PrimaryNav —— 桌面主导航链接列表。
 *
 * 数据取自 site.ts 的 PRIMARY_NAV（单一来源，与 MobileNav 共用）。
 * 当前页用 isNavLinkActive 标 aria-current 并高亮。无 JS。
 * 外层 <nav> 与 aria-label 由调用方（SiteHeader / MobileNav）提供，
 * 这里只渲染列表，便于桌面/移动两处复用。
 */
import { PRIMARY_NAV, isNavLinkActive } from "@/lib/site";

type Props = {
  /** 当前请求路径，用于激活态。 */
  currentPath: string;
  /** 布局方向：横排（桌面）或竖排（抽屉）。 */
  orientation?: "horizontal" | "vertical";
};

const { currentPath, orientation = "horizontal" } = Astro.props;
---

<ul
  class:list={[
    "primary-nav",
    orientation === "vertical" && "primary-nav--vertical",
  ]}
>
  {
    PRIMARY_NAV.map((link) => {
      const active = isNavLinkActive(link.href, currentPath);
      return (
        <li>
          <a
            href={link.href}
            class:list={["nav-link", active && "is-active"]}
            aria-current={active ? "page" : undefined}
          >
            {link.label}
          </a>
        </li>
      );
    })
  }
</ul>

<style>
  .primary-nav {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.2vw, 2rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .primary-nav--vertical {
    flex-direction: column;
    align-items: stretch;
    gap: 0;
  }

  .nav-link {
    display: inline-block;
    color: inherit;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    letter-spacing: 0.01em;
    text-decoration: none;
    padding: 0.25rem 0;
    border-bottom: 1px solid transparent;
    transition:
      opacity 150ms ease,
      border-color 150ms ease;
  }
  .nav-link:hover {
    opacity: 0.7;
  }
  .nav-link.is-active {
    border-bottom-color: currentColor;
  }

  /* 竖排（抽屉）：更大点按区、行分隔，serif 调性。 */
  .primary-nav--vertical .nav-link {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
  }
  .primary-nav--vertical .nav-link.is-active {
    opacity: 1;
    font-style: italic;
  }
</style>
