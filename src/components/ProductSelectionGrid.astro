---
/**
 * ProductSelectionGrid —— 首页「Our Products Selection」四入口网格。
 *
 * 入口数据来自 PRODUCT_SELECTION（src/lib/home.ts，单一来源），渲染为 4 张
 * ProductSelectionCard。桌面四列、平板两列、移动单列。纯静态（零 client JS）。
 *
 * 标题与颗粒度对照线上首页（heading「Our Products Selection」）。
 */
import ProductSelectionCard from "@/components/ProductSelectionCard.astro";
import { PRODUCT_SELECTION } from "@/lib/home";

/** 单张入口配图（asset->url + alt）。 */
type EntryImage = { url: string; alt: string | null } | null;

interface Props {
  /** 区块标题；缺省取线上首页文案。 */
  heading?: string;
  /** 入口配图，按入口 href 索引（如 /category/engineered-flooring → 该分类 heroImage）。 */
  imagesByHref?: Record<string, EntryImage>;
}

const { heading = "Our Products Selection", imagesByHref = {} } = Astro.props;
---

<section
  class="selection"
  aria-labelledby="product-selection-heading"
  data-motion-scene="products"
>
  <div class="selection__inner">
    <h2
      id="product-selection-heading"
      class="selection__heading"
      data-motion-layer="heading"
    >
      {heading}
    </h2>
    <ul class="selection__grid" role="list">
      {
        PRODUCT_SELECTION.map((entry) => (
          <li class="selection__item" data-motion-layer="card">
            <ProductSelectionCard
              label={entry.label}
              href={entry.href}
              imageAlt={imagesByHref[entry.href]?.alt ?? entry.imageAlt}
              imageUrl={imagesByHref[entry.href]?.url ?? null}
            />
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .selection {
    padding: var(--spacing-section) 1.25rem;
    background: var(--color-bg);
  }

  .selection__inner {
    max-width: 72rem;
    margin-inline: auto;
  }

  .selection__heading {
    margin: 0 0 2.5rem;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    text-align: center;
    color: var(--color-ink);
  }

  .selection__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  /* 平板：两列。 */
  @media (min-width: 36rem) {
    .selection__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* 桌面：四列（对照线上首页一行四入口）。 */
  @media (min-width: 60rem) {
    .selection__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
