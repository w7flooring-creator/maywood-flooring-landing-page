---
/**
 * ProductInquiryCta —— 产品详情页询盘行动区。
 *
 * Phase 1 无在线下单（见已敲定决策）：本区把访客导向询盘渠道——
 *  - 主 CTA：Enquire about this product → /contact（深色圆角小按钮，品牌外观）。
 *  - 辅助：phone（tel:）+ WhatsApp，取自 site.ts 单一来源（NAP 全站一致）。
 *
 * 产品名注入主 CTA 的 aria-label，方便屏幕阅读器分辨「就这个产品询盘」。
 * 纯静态（零 client JS）。
 */
import { NAP } from "@/lib/site";

interface Props {
  /** 产品名，用于 CTA 的无障碍标签。 */
  productTitle: string;
}

const { productTitle } = Astro.props;
const telHref = `tel:${NAP.phone.replace(/\s+/g, "")}`;
---

<section class="inquiry" aria-label="Enquire about this product">
  <a
    class="inquiry__cta"
    href="/contact"
    aria-label={`Enquire about this product: ${productTitle}`}
  >
    Enquire about this product
  </a>

  <p class="inquiry__channels">
    <span>Or speak to our team:</span>
    <a class="inquiry__link" href={telHref}>{NAP.phone}</a>
    <span aria-hidden="true" class="inquiry__sep">·</span>
    <a
      class="inquiry__link"
      href={NAP.whatsappUrl}
      target="_blank"
      rel="noopener noreferrer">WhatsApp</a
    >
  </p>
</section>

<style>
  .inquiry {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border-hairline);
  }

  .inquiry__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.75rem;
    background: var(--color-cta);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: var(--radius-cta);
    transition: opacity 0.2s ease;
  }

  .inquiry__cta:hover,
  .inquiry__cta:focus-visible {
    opacity: 0.85;
  }

  .inquiry__channels {
    margin: 1.25rem 0 0;
    font-size: 0.9375rem;
    color: var(--muted-foreground);
  }

  .inquiry__link {
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }

  .inquiry__link:hover,
  .inquiry__link:focus-visible {
    opacity: 0.7;
  }

  .inquiry__sep {
    margin: 0 0.4rem;
    color: var(--muted-foreground);
  }
</style>
