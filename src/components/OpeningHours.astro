---
/**
 * OpeningHours —— 营业时间表（Contact 页 "Contact Us" 区一栏）。
 *
 * 数据为静态（核对自线上 Wix Contact 页 2026-06；非 NAP，故不入 site.ts）。
 * Phase 1 硬编码；将来若入 Sanity siteSettings 再切数据源（同 NAP 思路）。
 * 用 <dl> 语义表达「日 → 时段」键值对，屏幕阅读器可正确朗读。
 */
import { OPENING_HOURS } from "@/lib/site";
---

<dl class="hours">
  {
    OPENING_HOURS.map((row) => (
      <div class="hours__row">
        <dt class="hours__days">{row.days}</dt>
        <dd class="hours__time">{row.hours}</dd>
      </div>
    ))
  }
</dl>

<style>
  .hours {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .hours__row {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .hours__days {
    font-size: 0.95rem;
    color: var(--color-ink);
  }
  .hours__time {
    margin: 0;
    font-size: 0.95rem;
    color: var(--muted-foreground);
  }
</style>
