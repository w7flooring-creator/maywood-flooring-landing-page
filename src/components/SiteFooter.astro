---
/**
 * SiteFooter —— 全站黑色 footer（见 AGENTS.md「视觉方向」「页面结构要点」）。
 *
 * 组成：大 serif 字标 + brand 简述 → quick links（复用 PRIMARY_NAV 单一来源）
 * → NAP（phone / email / address，全部取自 site.ts，禁止硬编码）
 * → phone / email / WhatsApp 联系 CTA → SocialLinks + AtfaBadge → 版权行。
 * NAP 用 <address> 语义包裹；phone=tel:、email=mailto:、WhatsApp=wa.me。
 */
import Logo from "@/components/Logo.astro";
import SocialLinks from "@/components/SocialLinks.astro";
import AtfaBadge from "@/components/AtfaBadge.astro";
import { NAP, FOOTER_NAV, SITE } from "@/lib/site";

const year = new Date().getFullYear();
// 拨号用的电话规整为 tel: 格式（去空格）。
const telHref = `tel:${NAP.phone.replace(/\s+/g, "")}`;
const { street, locality, region, postalCode } = NAP.address;
---

<footer class="site-footer on-ink">
  <div class="site-footer__inner">
    <div class="site-footer__top">
      <div class="site-footer__brand">
        <Logo size="lg" href="/" />
        <p class="site-footer__tagline">
          Premium timber, laminate and hybrid flooring — supplied to trade,
          wholesale and homeowners across Melbourne and Victoria.
        </p>
        <div class="site-footer__social">
          <SocialLinks />
          <AtfaBadge />
        </div>
      </div>

      <nav class="site-footer__links" aria-label="Footer">
        <h2 class="site-footer__heading">Explore</h2>
        <ul>
          {
            FOOTER_NAV.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="site-footer__contact">
        <h2 class="site-footer__heading">Get in touch</h2>
        <address class="site-footer__address">
          <a class="site-footer__line" href={telHref}>
            <span class="site-footer__label">Phone</span>
            {NAP.phone}
          </a>
          <a class="site-footer__line" href={`mailto:${NAP.email}`}>
            <span class="site-footer__label">Email</span>
            {NAP.email}
          </a>
          <a
            class="site-footer__line"
            href={NAP.whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="site-footer__label">WhatsApp</span>
            Message us
          </a>
          <p class="site-footer__line site-footer__line--static">
            <span class="site-footer__label">Showroom</span>
            {street}, {locality}, {region}
            {postalCode}
          </p>
        </address>
      </div>
    </div>

    <div class="site-footer__bottom">
      <p>&copy; {year} {SITE.name}. All rights reserved.</p>
      <p>Keysborough, VIC · Australia</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-ink);
    color: #fff;
  }
  .site-footer__inner {
    max-width: 80rem;
    margin-inline: auto;
    padding: clamp(3rem, 6vw, 5rem) clamp(1rem, 4vw, 2.5rem) 2rem;
  }

  .site-footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
  }
  @media (min-width: 48rem) {
    .site-footer__top {
      grid-template-columns: 1.6fr 1fr 1.2fr;
    }
  }

  .site-footer__tagline {
    max-width: 30rem;
    margin: 1.25rem 0 1.75rem;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .site-footer__social {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }

  .site-footer__heading {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 0 1.1rem;
  }

  .site-footer__links ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .site-footer__links a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 150ms ease;
  }
  .site-footer__links a:hover {
    color: #fff;
  }

  .site-footer__address {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .site-footer__line {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 150ms ease;
  }
  a.site-footer__line:hover {
    color: #fff;
  }
  .site-footer__line--static {
    margin: 0;
  }
  .site-footer__label {
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }

  .site-footer__bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: clamp(2.5rem, 5vw, 4rem);
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.8rem;
  }
  .site-footer__bottom p {
    margin: 0;
  }
</style>
