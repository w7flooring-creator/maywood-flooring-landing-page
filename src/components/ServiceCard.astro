---
/**
 * ServiceCard —— /book-online 列表页单卡（issue #20）。
 *
 * 整卡链接到 /service-page/<slug>。展示标题、时长（有则显示）、一句话摘要。
 * 无图（服务条目本身无品牌图，且生产禁止热链 Wix）——克制的 editorial 文本卡，
 * 不放破图 / 占位。纯静态（零 client JS）。
 */
import type { Service } from "@/lib/services";

interface Props {
  service: Service;
}

const { service } = Astro.props;
const href = `/service-page/${service.slug}`;
---

<a class="service-card" href={href}>
  {service.duration && <p class="service-card__duration">{service.duration}</p>}
  <h2 class="service-card__title">{service.title}</h2>
  <p class="service-card__summary">{service.summary}</p>
  <span class="service-card__more" aria-hidden="true">Learn more</span>
</a>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: clamp(1.5rem, 3vw, 2rem);
    background: var(--color-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-cta);
    color: inherit;
    text-decoration: none;
    transition: border-color 200ms ease;
  }

  .service-card__duration {
    margin: 0 0 0.75rem;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  .service-card__title {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    line-height: 1.15;
    color: var(--color-ink);
  }

  .service-card__summary {
    margin: 0.85rem 0 0;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--muted-foreground);
  }

  .service-card__more {
    margin-top: auto;
    padding-top: 1.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink);
  }

  .service-card:hover,
  .service-card:focus-visible {
    border-color: var(--color-ink);
  }

  .service-card:hover .service-card__more,
  .service-card:focus-visible .service-card__more {
    text-decoration: underline;
  }
</style>
