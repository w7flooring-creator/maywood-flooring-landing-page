---
/**
 * SocialLinks —— 社媒图标链接条（footer 用）。
 *
 * 数据取自 site.ts 的 SOCIAL_LINKS（单一来源，核对线上 Social Bar）。
 * 图标为内联 lucide SVG（静态页不为图标 hydrate React，零额外 JS）。
 * 外链 target=_blank + rel=noopener；每个链接有 aria-label，SVG aria-hidden。
 */
import { SOCIAL_LINKS } from "@/lib/site";

type Props = {
  class?: string;
};
const { class: className } = Astro.props;

// lucide 图标的 <path>（统一 24×24、stroke 风格），按 icon 标识取用。
const ICON_PATHS: Record<string, string> = {
  instagram:
    '<rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>',
  facebook:
    '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>',
  youtube:
    '<path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/>',
};
---

<ul class:list={["social-links", className]} aria-label="Social media">
  {
    SOCIAL_LINKS.map((social) => (
      <li>
        <a
          href={social.href}
          class="social-links__link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${social.label} (opens in a new tab)`}
        >
          <svg
            class="social-links__icon"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            focusable="false"
            set:html={ICON_PATHS[social.icon]}
          />
        </a>
      </li>
    ))
  }
</ul>

<style>
  .social-links {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .social-links__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    color: inherit;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 50%;
    transition:
      background-color 150ms ease,
      border-color 150ms ease;
  }
  .social-links__link:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.4);
  }
</style>
