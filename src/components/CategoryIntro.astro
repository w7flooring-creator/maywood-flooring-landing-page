---
/**
 * CategoryIntro —— 分类页的 H1 + 介绍文字。
 *
 * 承担页面**唯一 H1**（分类展示名），故无论 description 是否存在都渲染 H1。
 * description 由编辑在 Studio 填，是「内容债」修复点：误导 slug 的 Laminate /
 * Hybrid 分类，其文案以 Sanity description 为准（编辑可改成与实际材质相符），
 * **不在代码里硬编码材质措辞**（见 ADR-0001 内容债）。
 *
 *  - 有 description：按段落（空行）切分渲染纯文本。
 *  - 无 description：只渲染 H1，绝不输出 lorem / 占位文案。
 *
 * 纯静态（零 client JS）。
 */
interface Props {
  title: string;
  description: string | null;
  /**
   * 标题旁的小装饰图标（lucide 标识，内联 SVG、零 JS，同 SocialLinks 惯例）。
   * #59-#20：仅 Laminate 分类对齐 Wix 的标题小图标；缺省不渲染。
   * 纯装饰 → aria-hidden，不参与可访问名称。
   */
  icon?: "layers" | null;
}

const { title, description, icon = null } = Astro.props;

// 把多行纯文本按空行切成段落，过滤空段；无内容则只渲染 H1。
const paragraphs = (description ?? "")
  .split(/\n\s*\n/)
  .map((p) => p.trim())
  .filter((p) => p.length > 0);
const hasDescription = paragraphs.length > 0;
---

<header class="intro" data-motion-scene="text">
  <h1 class="intro__title" data-motion-layer="heading">
    {
      icon === "layers" && (
        <svg
          class="intro__icon"
          aria-hidden="true"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          {/* lucide "layers" —— 层压板的分层结构语义。 */}
          <path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z" />
          <path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65" />
          <path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65" />
        </svg>
      )
    }
    <span>{title}</span>
  </h1>
  {
    hasDescription && (
      <div class="intro__body" data-motion-layer="copy">
        {paragraphs.map((p) => (
          <p class="intro__para">{p}</p>
        ))}
      </div>
    )
  }
</header>

<style>
  .intro {
    max-width: 48rem;
  }

  .intro__title {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1.1;
    color: var(--color-ink);
    display: flex;
    align-items: center;
    gap: 0.4em;
  }

  /* 标题旁小装饰图标：随标题字号缩放（em），克制细线风格。 */
  .intro__icon {
    width: 0.72em;
    height: 0.72em;
    flex-shrink: 0;
  }

  .intro__body {
    margin-top: 1.25rem;
  }

  .intro__para {
    margin: 0 0 1rem;
    font-size: 1.0625rem;
    line-height: 1.7;
    color: #333;
  }

  .intro__para:last-child {
    margin-bottom: 0;
  }
</style>
