---
/**
 * ProductSelectionCard —— 首页产品入口单卡（图 + label，整卡可点）。
 *
 * 设计为「无图也好看」：Phase 1 尚未把品牌图入库（生产禁止热链 Wix），
 * 故 imageUrl 缺省时回落到克制的暖色 muted 占位块（绝不放占位 lorem / 破图），
 * 编辑后续给入库即自动「亮起」。纯静态（零 client JS）。
 *
 * 图片均在首屏下方 → lazy load（below-the-fold，见 AGENTS.md / #15 验收）。
 */
import { sanityImageUrl, sanityImageSrcset } from "@/lib/sanity-image";

interface Props {
  label: string;
  href: string;
  imageAlt: string;
  /** 入库后的图片 URL；Phase 1 恒空 → 回落占位块。 */
  imageUrl?: string | null;
}

const { label, href, imageAlt, imageUrl = null } = Astro.props;
const hasImage = imageUrl !== null;
---

<a class="card" href={href}>
  <span class="card__media">
    {
      hasImage ? (
        <img
          class="card__img"
          src={sanityImageUrl(imageUrl, { width: 640 })}
          srcset={sanityImageSrcset(imageUrl, [320, 480, 640]) || undefined}
          sizes="(min-width: 60rem) 25vw, 50vw"
          alt={imageAlt}
          loading="lazy"
          decoding="async"
        />
      ) : (
        <span class="card__img card__img--empty" aria-hidden="true" />
      )
    }
  </span>
  <span class="card__label">{label}</span>
</a>

<style>
  .card {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .card__media {
    display: block;
    overflow: hidden;
    background: var(--color-bg-muted);
  }

  .card__img {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    background: var(--color-bg-muted);
    border: 1px solid var(--border);
  }

  /* 无图回落：暖色 muted 块（呼应品牌背景），保持版式与有图态一致。 */
  .card__img--empty {
    background: var(--color-bg-muted);
  }

  .card__label {
    display: block;
    margin-top: 1rem;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    color: var(--color-ink);
  }

  /* 整卡可点：hover/focus 时 label 下划线 + 图片轻微提亮（克制，无花哨动效）。 */
  .card:hover .card__label,
  .card:focus-visible .card__label {
    text-decoration: underline;
  }

  @media (prefers-reduced-motion: no-preference) {
    .card__img {
      transition:
        opacity 500ms ease,
        transform 800ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    .card:hover .card__img,
    .card:focus-visible .card__img {
      opacity: 0.92;
      transform: scale(1.035);
    }
  }
</style>
