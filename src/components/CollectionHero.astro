---
/**
 * CollectionHero —— 招牌系列营销落地页顶部 hero。
 *
 * 设计为「内容未灌入也好看」：
 *  - 有 heroImage：宽幅暖色主图 + 白色内容面板叠放系列名（呼应首页 hero）。
 *  - 无 heroImage：克制的居中 serif 大标题，留白主导，绝不放占位图/lorem。
 *
 * 纯静态（零 client JS）。视觉用品牌 token（serif 大标题、muted 背景、editorial 留白）。
 */
import type { CollectionHeroImage } from "@/lib/collection-landing";
import { sanityImageUrl, sanityImageSrcset } from "@/lib/sanity-image";

interface Props {
  title: string;
  /** 可选 eyebrow（如所属 Category 名）；缺省不渲染。 */
  eyebrow?: string | null;
  image?: CollectionHeroImage | null;
}

const { title, eyebrow = null, image = null } = Astro.props;
// 仅当真正有可渲染 url 才算有图（heroImage 字段可能存在但 asset 为空 → url null）。
const hasImage = image?.url != null && image.url.length > 0;
// hero 图在首屏 → 不 lazy load（首屏 LCP 元素）；alt 缺省给空串（装饰性回落）。
const altText = image?.alt ?? "";
---

<section class:list={["hero", { "hero--image": hasImage }]}>
  {
    hasImage && (
      <img
        class="hero__bg"
        src={sanityImageUrl(image!.url, { width: 1440 })}
        srcset={
          sanityImageSrcset(image!.url, [768, 1080, 1440, 1920]) || undefined
        }
        sizes="100vw"
        alt={altText}
        fetchpriority="high"
        loading="eager"
        decoding="async"
      />
    )
  }
  <div class="hero__panel">
    {eyebrow && <p class="hero__eyebrow">{eyebrow}</p>}
    <h1 class="hero__title">{title}</h1>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: clamp(18rem, 38vw, 30rem);
    padding: var(--spacing-section) 1.25rem;
    background: var(--color-bg-muted);
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  /* 有图时给内容面板一块白底，保证 serif 标题对比度（呼应首页 hero 白面板）。 */
  .hero--image .hero__panel {
    position: relative;
    z-index: 1;
    background: var(--color-bg);
    padding: clamp(2rem, 5vw, 3.5rem);
    max-width: 44rem;
    text-align: center;
  }

  .hero__panel {
    text-align: center;
  }

  .hero__eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #777;
  }

  .hero__title {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.05;
    color: var(--color-ink);
  }
</style>
