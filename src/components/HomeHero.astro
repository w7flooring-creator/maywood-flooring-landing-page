---
/**
 * HomeHero —— 首页 hero：室内 lifestyle 图 + 叠放的白色内容面板
 * （H1 + tagline + 简介段 + READ MORE CTA），对照线上 Wix 首页结构。
 *
 * 文案来自 HOME_HERO（src/lib/home.ts，单一来源）。H1 是全页唯一 H1。
 * 设计为「无图也好看」：Phase 1 尚未把品牌图入库（生产禁止热链 Wix），
 * imageUrl 缺省时回落到暖色 muted 背景（绝不放占位图 / 破图）。
 *
 * hero 图在首屏 → eager 加载（首屏 LCP 元素），呼应 CollectionHero 取舍。
 * 纯静态（零 client JS）。
 */
import { HOME_HERO } from "@/lib/home";
import { sanityImageUrl, sanityImageSrcset } from "@/lib/sanity-image";

interface Props {
  /** 入库后的室内图 URL；Phase 1 恒空 → muted 背景回落。 */
  imageUrl?: string | null;
  /** 室内图 alt（有意义文案，仅有图时输出）。 */
  imageAlt?: string;
}

const {
  imageUrl = null,
  imageAlt = "Maywood timber flooring in a light-filled luxury interior.",
} = Astro.props;
const hasImage = imageUrl !== null;
---

<section class:list={["hero", { "hero--image": hasImage }]}>
  {
    hasImage && (
      <img
        class="hero__bg"
        src={sanityImageUrl(imageUrl, { width: 1440 })}
        srcset={
          sanityImageSrcset(imageUrl, [768, 1080, 1440, 1920]) || undefined
        }
        sizes="100vw"
        alt={imageAlt}
        fetchpriority="high"
        loading="eager"
        decoding="async"
      />
    )
  }
  <div class="hero__panel">
    <h1 class="hero__title">{HOME_HERO.heading}</h1>
    <p class="hero__tagline">{HOME_HERO.tagline}</p>
    <p class="hero__intro">{HOME_HERO.intro}</p>
    <a
      class="hero__cta"
      href={HOME_HERO.cta.href}
      aria-label={`${HOME_HERO.cta.label} about Maywood Flooring`}
      >{HOME_HERO.cta.label}</a
    >
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    min-height: clamp(28rem, 60vw, 42rem);
    padding: var(--spacing-section) 1.25rem;
    background: var(--color-bg-muted);
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  /* 白色内容面板：呼应线上 hero 的白底文字块，保证 serif 标题对比度。 */
  .hero__panel {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 38rem;
    margin-inline: auto;
    background: var(--color-bg);
    padding: clamp(1.75rem, 5vw, 3.25rem);
    border: 1px solid var(--border);
  }

  /* 有图时面板靠左叠放（editorial 留白），桌面不占满宽。 */
  .hero--image .hero__panel {
    margin-inline: 0;
  }

  .hero__title {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    line-height: 1.08;
    color: var(--color-ink);
  }

  .hero__tagline {
    margin: 1rem 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.1rem, 2.4vw, 1.4rem);
    color: var(--color-ink);
  }

  .hero__intro {
    margin: 1.5rem 0 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--muted-foreground);
  }

  /* 深色圆角小 CTA（呼应 SampleRequestButton 的品牌按钮语言）。 */
  .hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 2rem;
    background: var(--color-cta);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.7rem 1.5rem;
    border-radius: var(--radius-cta);
    border: 1px solid transparent;
    transition: background-color 150ms ease;
  }
  .hero__cta:hover {
    background: #2c2c2c;
  }

  @media (min-width: 60rem) {
    .hero {
      padding-inline: clamp(2rem, 6vw, 6rem);
    }
  }
</style>
