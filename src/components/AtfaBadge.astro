---
/**
 * AtfaBadge —— ATFA（Australasian Timber Flooring Association）会员标识。
 *
 * 图形徽标（#59-#5）：站主自有授权素材，源自其 Wix 媒体库
 * （eb4477_07f55deb…，含 ATFA Member + BSI ISO 9001 双标识，与 Wix 页脚一致）。
 * 已压缩入仓：public/images/atfa-member-badge.jpg（720×169，约 38KB）。
 * 徽标为白底 → 包在白色圆角小卡内置于黑色 footer，克制不花哨。
 */
type Props = {
  class?: string;
};
const { class: className } = Astro.props;
---

<span
  class:list={["atfa-badge", className]}
  title="Australasian Timber Flooring Association member · ISO 9001 certified"
>
  <img
    src="/images/atfa-member-badge.jpg"
    alt="ATFA member — Australasian Timber Flooring Association; BSI ISO 9001 certified"
    width="720"
    height="169"
    loading="lazy"
    decoding="async"
  />
</span>

<style>
  /* 白色圆角小卡：徽标原图为白底，垫白卡在黑 footer 上呈现干净边界。 */
  .atfa-badge {
    display: inline-flex;
    align-items: center;
    background: #fff;
    border-radius: var(--radius-cta);
    padding: 0.4rem 0.6rem;
  }
  .atfa-badge img {
    display: block;
    width: auto;
    height: 2.1rem;
  }
</style>
