---
/**
 * Logo —— serif 字标（wordmark），全站 header / footer 复用。
 *
 * 用字标而非图片：保证 SEO 文本可读、清晰可缩放、零额外资源；
 * Fraunces serif 主导品牌视觉（见 AGENTS.md「视觉方向」）。
 * 包裹链接默认回首页；`as` 可切换标签（首页用 <span> 避免自指链接）。
 */
import { SITE } from "@/lib/site";

type Props = {
  /** 视觉尺寸档位：header 用 sm，footer 大字标用 lg。 */
  size?: "sm" | "lg";
  /** 是否包一层回首页的链接（首页自身传 false）。 */
  href?: string | null;
  class?: string;
};

const { size = "sm", href = "/", class: className } = Astro.props;
const sizeClass = size === "lg" ? "logo--lg" : "logo--sm";
---

{
  href ? (
    <a
      class:list={["logo", sizeClass, className]}
      href={href}
      aria-label={`${SITE.name} — home`}
    >
      {SITE.name}
    </a>
  ) : (
    <span class:list={["logo", sizeClass, className]}>{SITE.name}</span>
  )
}

<style>
  .logo {
    display: inline-block;
    font-family: var(--font-serif);
    font-weight: 500;
    letter-spacing: 0.01em;
    line-height: 1;
    color: inherit;
    text-decoration: none;
    white-space: nowrap;
  }
  .logo--sm {
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
  }
  .logo--lg {
    font-size: clamp(2rem, 6vw, 3.25rem);
  }
  .logo:where(a):hover {
    opacity: 0.85;
  }
</style>
