---
/**
 * Logo —— 品牌 wordmark 图片，全站 header / footer 复用。
 *
 * 白色 “MAYWOOD FLOORING” 字标（透明背景），用于深色 header / footer。
 * 用 astro:assets `<Image>` 处理：自动优化、按用途输出合适尺寸。
 * 包裹链接默认回首页；首页传 href={null} 改用 <span> 避免自指链接。
 */
import { Image } from "astro:assets";
import logoSrc from "@/assets/maywood-logo.avif";
import { SITE } from "@/lib/site";

type Props = {
  /** 视觉尺寸档位：header 用 sm，footer 大字标用 lg。 */
  size?: "sm" | "lg";
  /** 是否包一层回首页的链接（首页自身传 false）。 */
  href?: string | null;
  class?: string;
};

const { size = "sm", href = "/", class: className } = Astro.props;
const sizeClass = size === "lg" ? "logo--lg" : "logo--sm";
const alt = `${SITE.name} — home`;
const widths = size === "lg" ? [320, 480, 602] : [106, 160, 212];
const sizes =
  size === "lg"
    ? "(min-width: 60rem) 384px, 80vw"
    : "(min-width: 60rem) 120px, 106px";
---

{
  href ? (
    <a class:list={["logo", sizeClass, className]} href={href} aria-label={alt}>
      <Image
        src={logoSrc}
        alt={alt}
        class="logo__img"
        widths={widths}
        sizes={sizes}
        quality={70}
        loading="eager"
      />
    </a>
  ) : (
    <span class:list={["logo", sizeClass, className]}>
      <Image
        src={logoSrc}
        alt={SITE.name}
        class="logo__img"
        widths={widths}
        sizes={sizes}
        quality={70}
        loading="eager"
      />
    </span>
  )
}

<style>
  .logo {
    display: inline-block;
    line-height: 0;
    color: inherit;
    text-decoration: none;
  }
  .logo__img {
    display: block;
  }
  /* header：按高度控制，宽度自适应。 */
  .logo--sm .logo__img {
    width: auto;
    height: clamp(2.25rem, 4.5vw, 3rem);
  }
  /* footer：按宽度铺满 brand 栏（与 tagline 的 30rem 上限一致）。 */
  .logo--lg {
    display: block;
    width: min(80%, 24rem);
  }
  .logo--lg .logo__img {
    width: 100%;
    height: auto;
  }
  .logo:where(a):hover .logo__img {
    opacity: 0.85;
  }
</style>
