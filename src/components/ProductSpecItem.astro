---
/**
 * ProductSpecItem —— 规格表中的一行（label / value 对）。
 *
 * 用 <div role="row"> + 两个 cell 语义；作为 <dl> 项时由 ProductSpecList 包裹
 * （这里实际渲染 <dt>/<dd>，见下）。只有有值才会被 ProductSpecList 传进来，
 * 故本组件不做判空（空值过滤在 buildProductSpecItems）。纯静态。
 */
interface Props {
  label: string;
  value: string;
}

const { label, value } = Astro.props;
---

<div class="spec-item" data-motion-layer="copy">
  <dt class="spec-item__label">{label}</dt>
  <dd class="spec-item__value">{value}</dd>
</div>

<style>
  .spec-item {
    display: grid;
    grid-template-columns: minmax(8rem, 12rem) 1fr;
    gap: 1rem;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--color-border-hairline);
  }

  .spec-item:first-child {
    border-top: 1px solid var(--color-border-hairline);
  }

  .spec-item__label {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  .spec-item__value {
    margin: 0;
    font-size: 1rem;
    color: var(--color-ink);
  }

  @media (max-width: 30rem) {
    .spec-item {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
