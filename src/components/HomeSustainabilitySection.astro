---
/**
 * HomeSustainabilitySection —— 首页 Sustainability 图文区（图右、文左，呼应 Wix）。
 *
 * 对照线上首页独立 Sustainability 区块：标题 + responsibly managed plantation
 * forests 文案 + 配图 + Read More → /sustainability。文案来自 HOME_SUSTAINABILITY
 * （src/lib/home-narrative.ts，单一来源）；配图由调用页从 Sanity
 * homePage.sustainabilityImage 传入（生产不热链 Wix）。
 *
 * 无图时优雅降级为纯文字块（不放占位图）。区块标题用 h2（首页唯一 h1 归 hero）。
 * 纯静态（零 client JS）。
 */
import { HOME_SUSTAINABILITY } from "@/lib/home-narrative";
import { sanityImageUrl, sanityImageSrcset } from "@/lib/sanity-image";

interface Props {
  /** 区块配图（Sanity homePage.sustainabilityImage）；缺省 → 纯文字降级。 */
  image?: { url: string; alt: string | null } | null;
}

const { image = null } = Astro.props;
const { eyebrow, heading, paragraphs, cta } = HOME_SUSTAINABILITY;
const hasImage = image !== null;
---

<section class="sustain" aria-labelledby="sustain-heading">
  <div class:list={["sustain__inner", { "sustain__inner--image": hasImage }]}>
    <div class="sustain__text">
      {eyebrow && <p class="sustain__eyebrow">{eyebrow}</p>}
      <h2 id="sustain-heading" class="sustain__heading">{heading}</h2>
      <div class="sustain__body">
        {paragraphs.map((para) => <p class="sustain__para">{para}</p>)}
      </div>
      <a class="sustain__cta" href={cta.href}
        >{cta.label}<span class="sr-only">
          about Maywood sustainability</span
        ></a
      >
    </div>
    {
      hasImage && (
        <div class="sustain__media">
          <img
            class="sustain__img"
            src={sanityImageUrl(image!.url, { width: 960 })}
            srcset={
              sanityImageSrcset(image!.url, [480, 768, 1080]) || undefined
            }
            sizes="(min-width: 60rem) 48vw, 100vw"
            alt={image!.alt ?? ""}
            loading="lazy"
            decoding="async"
          />
        </div>
      )
    }
  </div>
</section>

<style>
  .sustain {
    padding: var(--spacing-section) 1.25rem;
    background: var(--color-bg);
  }

  .sustain__inner {
    max-width: 72rem;
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  .sustain__media {
    overflow: hidden;
    border-radius: var(--radius-cta);
    background: var(--color-bg-muted);
  }

  .sustain__img {
    display: block;
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .sustain__eyebrow {
    margin: 0 0 0.75rem;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  .sustain__heading {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1.12;
    color: var(--color-ink);
  }

  .sustain__body {
    margin-top: 1.5rem;
  }

  .sustain__para {
    margin: 0 0 1.25rem;
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--muted-foreground);
  }

  .sustain__para:last-child {
    margin-bottom: 0;
  }

  /* 深色圆角小 CTA（品牌按钮语言）。 */
  .sustain__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.75rem;
    background: var(--color-cta);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.7rem 1.5rem;
    border-radius: var(--radius-cta);
    transition: background-color 150ms ease;
  }
  .sustain__cta:hover {
    background: #2c2c2c;
  }

  /* 桌面：文左、图右双栏（与 Partner 图左形成节奏对比）。无图时单列纯文字。 */
  @media (min-width: 60rem) {
    .sustain__inner--image {
      grid-template-columns: 1fr 1fr;
      gap: clamp(3rem, 6vw, 5rem);
    }
  }
</style>
