---
// 品牌字体（self-host，Vite 打包，不热链）。变量字体覆盖各字重。
import "@fontsource-variable/fraunces";
import "@fontsource-variable/hanken-grotesk";
import "../styles/globals.css";
import SeoHead from "@/components/SeoHead.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SiteTransitionController from "@/components/SiteTransitionController.astro";
import PageMotionController from "@/components/PageMotionController.astro";
import { ClientRouter } from "astro:transitions";
import type { SeoInput } from "@/lib/seo";
import type { MotionProfile } from "@/lib/motion";

/**
 * 全站基础布局。SEO 元信息交给 SeoHead 统一处理（唯一 title/desc、canonical、
 * Open Graph、站点级 LocalBusiness JSON-LD），保证每页一致。
 *
 * 页面只需传 SeoInput 字段；`path` 缺省取当前页 pathname。
 * 页面级额外 <head> 内容（如页面专属结构化数据）走 `head` 具名 slot。
 */
type Props = Partial<SeoInput> & {
  /** 是否输出站点级 LocalBusiness（默认 true，详情页可叠加自己的 schema）。 */
  localBusiness?: boolean;
  /** 内页渐进式动效强度；首页使用独立控制器，内部页可传 none。 */
  motionProfile?: MotionProfile;
  /** 页面间转场视觉强度；首页显式传 home，其他页面默认沿用 motionProfile。 */
  transitionProfile?: "home" | MotionProfile;
  /** 内部页面可关闭客户端页面转场。 */
  pageTransitions?: boolean;
};

const {
  localBusiness = true,
  motionProfile = "none",
  transitionProfile = motionProfile === "none" ? "minimal" : motionProfile,
  pageTransitions = true,
  ...seo
} = Astro.props;
// path 缺省取当前请求路径，页面无需手动传。
const path = seo.path ?? Astro.url.pathname;
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {
      /* 图片走 Sanity 图片 CDN（见 src/lib/sanity-image.ts）：提前建连，加速 LCP 主图。 */
    }
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.sanity.io" />
    <SeoHead {...seo} path={path} localBusiness={localBusiness} />
    {pageTransitions && <ClientRouter fallback="animate" />}
    <slot name="head" />
  </head>
  <body
    data-transition-profile={pageTransitions ? transitionProfile : undefined}
    style={pageTransitions
      ? `--maywood-cold-enter-y: ${transitionProfile === "home" ? "0px" : "10px"}`
      : undefined}
  >
    <SiteHeader transition:name={pageTransitions ? "site-header" : undefined} />
    {
      pageTransitions && (
        <div class="site-navigation-indicator" aria-hidden="true">
          <span />
        </div>
      )
    }
    <main
      data-page-motion={motionProfile !== "none" ? "" : undefined}
      data-motion-profile={motionProfile !== "none" ? motionProfile : undefined}
      transition:name={pageTransitions ? "page-main" : undefined}
    >
      <slot />
    </main>
    {motionProfile !== "none" && <PageMotionController />}
    <SiteFooter />
    {pageTransitions && <SiteTransitionController />}
  </body>
</html>
