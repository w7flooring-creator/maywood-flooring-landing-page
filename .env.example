# Sanity
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
# 只读 token：build 时拉取内容需要（该 dataset 匿名读返回空，见 docs/adr/0003）。
# 敏感值，勿提交；CI 用 GitHub Secret，Cloudflare 用 Worker Secret。
SANITY_API_READ_TOKEN=

# 表单 / 获客（Phase 2：Cloudflare Worker，运行时 secret，不进客户端 bundle）
RESEND_API_KEY=
LEADS_TO_EMAIL=
TURNSTILE_SECRET_KEY=
# 发件人（可选）：默认 'Maywood Flooring <onboarding@resend.dev>'；
# 设为已在 Resend 验证的域名地址后即用自有域名发信。
CONTACT_FROM_EMAIL=
# Turnstile site key 为公开值，可安全进客户端 bundle。
PUBLIC_TURNSTILE_SITE_KEY=
